<meta charset="UTF-8">
<title>拼豆计数工具</title>
<style>
body { font-family: Arial; padding: 20px; }
h2, h3 { margin-bottom: 10px; }
.controls { margin-bottom: 15px; }
.palette { display: grid; grid-template-columns: repeat(auto-fill, 140px); gap: 10px; }
.color { display: flex; align-items: center; border: 1px solid #ccc; padding: 5px; }
.box { width: 30px; height: 30px; margin-right: 8px; border: 1px solid #999; cursor: default; }
.text { font-size: 12px; width: 60px; }
input { width: 50px; }
.stats { margin-top: 20px; }
button { margin: 5px; padding: 5px 8px; cursor: pointer; }
#batchModal { display: none; position: fixed; top: 50%; left: 50%;
  transform: translate(-50%, -50%); background: #fff; border: 2px solid #333;
  padding: 15px; max-height: 80%; overflow-y: auto; z-index: 100; width: 300px; }
#overlay { display: none; position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.3); z-index: 50; }
#batchModal input { width: 100px; margin-bottom: 5px; }
</style>
</head>
