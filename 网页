<h2>拼豆计数工具</h2>

<div class="controls">
  <button onclick="openBatchModal()">批量修改数量</button>
  <button onclick="exportExcel()">导出 Excel</button>
</div>

<div class="palette" id="palette"></div>

<h3>统计</h3>
<ul id="stats"></ul>

<div id="overlay"></div>
<div id="batchModal">
  <h3>批量修改数量</h3>
  <p>输入颜色编号和数量（例如：A1 120, B3 45）每行一个</p>
  <textarea id="batchInput" rows="10" style="width:100%;"></textarea><br>
  <button onclick="saveBatch()">保存</button>
  <button onclick="closeBatchModal()">取消</button>
</div>

