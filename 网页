// 排序（系列内按编号）
mardColors.sort((a,b)=>{
  if(a.series!==b.series) return a.series.localeCompare(b.series);
  const numA = parseInt(a.code.match(/\d+/)[0]);
  const numB = parseInt(b.code.match(/\d+/)[0]);
  return numA - numB;
});

// ====== 初始化计数 ======
const counts = {};
mardColors.forEach(c=>counts[c.code]=0);

const palette = document.getElementById("palette");
const stats = document.getElementById("stats");

// ====== 渲染色板 ======
function renderPalette(){
  palette.innerHTML = "";
  let currentSeries = "";
  mardColors.forEach(c=>{
    if(c.series!==currentSeries){
      const h3 = document.createElement("h3");
      h3.innerText = c.series;
      palette.appendChild(h3);
      currentSeries = c.series;
    }

    const div = document.createElement("div");
    div.className = "color";

    const box = document.createElement("div");
    box.className = "box";
    box.style.background = c.hex;
    // 点击不触发计数
    box.title = c.code + " " + c.hex;

    const text = document.createElement("div");
    text.className = "text";
    text.innerHTML = `<b>${c.code}</b><br>${c.hex}`;

    const input = document.createElement("input");
    input.type = "number";
    input.value = counts[c.code];
    input.oninput = ()=>{ counts[c.code] = parseInt(input.value)||0; updateStats(); };

    div.appendChild(box);
    div.appendChild(text);
    div.appendChild(input);

    palette.appendChild(div);
  });
}

// ====== 更新统计 ======
function updateStats(){
  stats.innerHTML = "";
  for(let key in counts){
    if(counts[key]>0){
      const li = document.createElement("li");
      li.innerText = `${key}: ${counts[key]}`;
      stats.appendChild(li);
    }
  }
}

// ====== 批量修改窗口 ======
const batchModal = document.getElementById("batchModal");
const overlay = document.getElementById("overlay");

function openBatchModal(){
  document.getElementById("batchInput").value = "";
  overlay.style.display="block";
  batchModal.style.display="block";
}

function closeBatchModal(){
  overlay.style.display="none";
  batchModal.style.display="none";
}

function saveBatch(){
  const lines = document.getElementById("batchInput").value.split("\n");
  lines.forEach(line=>{
    const parts = line.trim().split(/\s+/);
    if(parts.length===2){
      const code = parts[0];
      const num = parseInt(parts[1]);
      if(code in counts && !isNaN(num)){
        counts[code] = num;
      }
    }
  });
  renderPalette();
  updateStats();
  closeBatchModal();
}

// ====== 导出 Excel (CSV) ======
function exportExcel(){
  let csv = "编号,数量,HEX\n";
  colors.forEach(c=>{
    csv += `${c.code},${counts[c.code]},${c.hex}\n`;
  });
  const blob = new Blob([csv], {type: "text/csv;charset=utf-8"});
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = "拼豆数量统计.csv";
  a.click();
  URL.revokeObjectURL(url);
}

